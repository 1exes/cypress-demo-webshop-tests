# Cypress Test Environment Variables
# Copy this file to .env and fill in your actual values

# Test User Credentials
CYPRESS_TEST_EMAIL=your-test-email@example.com
CYPRESS_TEST_PASSWORD=your-secure-password

# Application URLs
CYPRESS_BASE_URL=https://demowebshop.tricentis.com

# Test Credit Card (for demo purposes only)
CYPRESS_TEST_CC_NUMBER=4111111111111111
CYPRESS_TEST_CC_HOLDER=Test User
CYPRESS_TEST_CC_CVV=123

# Test User Details
CYPRESS_TEST_FIRST_NAME=John
CYPRESS_TEST_LAST_NAME=Doe
CYPRESS_TEST_COMPANY=Test Company
CYPRESS_TEST_ADDRESS=123 Test Street
CYPRESS_TEST_CITY=Test City
CYPRESS_TEST_ZIP=12345
CYPRESS_TEST_PHONE=+49123456789
